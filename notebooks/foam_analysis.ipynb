        "# Функция для обнаружения аномалий\n",
        "def detect_anomalies(values, threshold=3):\n",
        "    \"\"\"Обнаружение аномалий по z-score.\"\"\"\n",
        "    z_scores = np.abs(stats.zscore(values))\n",
        "    return z_scores > threshold\n",
        "\n",
        "fig, axes = plt.subplots(len(foam_data), 1, figsize=(14, 4*len(foam_data)))\n",
        "\n",
        "for i, (level, values) in enumerate(foam_data.items()):\n",
        "    ax = axes[i] if len(foam_data) > 1 else axes\n",
        "    \n",
        "    anomalies = detect_anomalies(values)\n",
        "    \n",
        "    ax.plot(steps, values, 'b-', alpha=0.7, label='Нормальные')\n",
        "    ax.scatter(steps[anomalies], values[anomalies], \n",
        "               color='red', s=50, label='Аномалии', zorder=5)\n",
        "    ax.set_xlabel('Шаг')\n",
        "    ax.set_ylabel(f'Пена G{level}')\n",
        "    ax.set_title(f'Аномалии в пене G{level} (найдено {sum(anomalies)})')\n",
        "    ax.legend()\n",
