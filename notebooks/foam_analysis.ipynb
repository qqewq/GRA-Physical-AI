      "outputs": [],
      "source": [
        "def load_logs(file_pattern, max_files=None):\n",
        "    \"\"\"Загружает логи из нескольких файлов в один DataFrame.\"\"\"\n",
        "    all_data = []\n",
        "    \n",
        "    files = glob.glob(file_pattern, recursive=True)\n",
        "    if max_files:\n",
        "        files = files[:max_files]\n",
        "    \n",
        "    for file_path in files:\n",
        "        try:\n",
        "            if file_path.endswith('.jsonl'):\n",
        "                # Загрузка JSONL\n",
        "                df = pd.read_json(file_path, lines=True)\n",
        "            elif file_path.endswith('.csv'):\n",
        "                # Загрузка CSV\n",
        "                df = pd.read_csv(file_path)\n",
        "            else:\n",
        "                continue\n",
        "            \n",
        "            # Добавляем колонку с именем файла\n",
        "            df['source_file'] = os.path.basename(file_path)\n",
        "            df['source_dir'] = os.path.dirname(file_path)\n",
        "            all_data.append(df)\n",
        "            print(f\"✅ Загружен {file_path}: {len(df)} строк\")\n",
        "        except Exception as e:\n",
        "            print(f\"❌ Ошибка загрузки {file_path}: {e}\")\n",
        "    \n",
        "    if all_data:\n",
        "        return pd.concat(all_data, ignore_index=True)\n",
        "    else:\n",
        "        return pd.DataFrame()\n",
        "\n",
