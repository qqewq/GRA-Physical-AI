      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Конфигурация Isaac Lab окружения\n",
        "isaac_config = {\n",
        "    'env_name': 'Isaac-Lift-Cube-Franka-v0',\n",
