        "ax.set_ylabel('Пена')\n",
        "ax.set_title('Динамика пены по уровням')\n",
        "ax.legend()\n",
        "ax.grid(True)\n",
        "\n",
        "# Награда\n",
        "ax = axes[0,1]\n",
        "ax.plot(steps, reward_history, color='green')\n",
        "ax.set_xlabel('Шаг')\n",
        "ax.set_ylabel('Награда')\n",
        "ax.set_title('Награда во времени')\n",
        "ax.grid(True)\n",
        "\n",
        "# Гистограмма пены\n",
        "ax = axes[1,0]\n",
        "all_foam = [v for values in foam_levels.values() for v in values]\n",
        "ax.hist(all_foam, bins=30, alpha=0.7, color='purple')\n",
        "ax.set_xlabel('Пена')\n",
        "ax.set_ylabel('Частота')\n",
        "ax.set_title('Распределение пены')\n",
        "ax.grid(True)\n",
        "\n",
        "# Корреляция пены и награды\n",
        "ax = axes[1,1]\n",
        "avg_foam = np.mean([foam_levels[0], foam_levels[1], foam_levels[2]], axis=0)\n",
        "ax.scatter(avg_foam, reward_history, alpha=0.5, color='blue')\n",
        "ax.set_xlabel('Средняя пена')\n",
        "ax.set_ylabel('Награда')\n",
        "ax.set_title('Корреляция пена-награда')\n",
        "ax.grid(True)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 7. Анализ: когда возникает пена?\n",
        "\n",
        "Проанализируем моменты, когда пена была максимальной."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Находим моменты с высокой пеной\n",
        "avg_foam = np.mean([foam_levels[0], foam_levels[1], foam_levels[2]], axis=0)\n",
        "threshold = np.percentile(avg_foam, 90)  # 90-й перцентиль\n",
        "high_foam_indices = np.where(avg_foam > threshold)[0]\n",
        "\n",
        "print(f\"🔍 Моменты высокой пены (> {threshold:.3f}):\")\n",
        "for idx in high_foam_indices[:5]:  # первые 5\n",
        "    print(f\"  Шаг {idx}: G0={foam_levels[0][idx]:.3f}, \"\n",
        "          f\"G1={foam_levels[1][idx]:.3f}, \"\n",
        "          f\"G2={foam_levels[2][idx]:.3f}\")\n",
        "\n",
        "# Анализ корреляций между уровнями\n",
        "corr_matrix = np.corrcoef([foam_levels[0], foam_levels[1], foam_levels[2]])\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8, 6))\n",
        "im = ax.imshow(corr_matrix, cmap='coolwarm', vmin=-1, vmax=1)\n",
        "ax.set_xticks([0, 1, 2])\n",
        "ax.set_yticks([0, 1, 2])\n",
        "ax.set_xticklabels(['G0', 'G1', 'G2'])\n",
        "ax.set_yticklabels(['G0', 'G1', 'G2'])\n",
        "ax.set_title('Корреляция пены между уровнями')\n",
        "\n",
        "# Добавляем значения в ячейки\n",
        "for i in range(3):\n",
        "    for j in range(3):\n",
        "        text = ax.text(j, i, f'{corr_matrix[i,j]:.2f}',\n",
        "                       ha='center', va='center', color='black')\n",
        "\n",
        "plt.colorbar(im)\n",
        "plt.show()"
      ]
    },
