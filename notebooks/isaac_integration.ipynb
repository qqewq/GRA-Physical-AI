        "# Преобразуем историю в массивы\n",
        "steps = np.arange(len(foam_history))\n",
        "\n",
        "# Извлекаем значения пены для каждого уровня\n",
        "foam_levels = {0: [], 1: [], 2: []}\n",
        "for f in foam_history:\n",
